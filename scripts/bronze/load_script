    "\n",
    "import pandas as pd\n",
    "import logging\n",
    "from datetime import datetime\n",
    "from sqlalchemy import create_engine, text\n",
    "from sqlalchemy.engine import URL\n",
    "\n",
    "# ================= CONFIGURATION =================\n",
    "DB_USER=\"root\"\n",
    "DB_PASSWORD=\"Your Password\"\n",
    "DB_HOST=\"localhost\"\n",
    "DB_PORT=3306\n",
    "DB_NAME=\"bronze\"\n",
    "\n",
    "DATASETS=[\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/CRM/cust_info.csv\",\"table\":\"crm_cust_info\"},\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/CRM/prd_info.csv\",\"table\":\"crm_prd_info\"},\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/CRM/sales_details.csv\",\"table\":\"crm_sales_details\"},\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/ERP/CUST_AZ12.csv\",\"table\":\"erp_cust_az12\"},\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/ERP/LOC_A101.csv\",\"table\":\"erp_loc_a101\"},\n",
    "{\"file_path\":r\"C:/Users/Mola/Desktop/Folders/Data Warehouse/Project/Dataset/ERP/PX_CAT_G1V2.csv\",\"table\":\"erp_px_cat_g1v2\"},\n",
    "]\n",
    "\n",
    "logging.basicConfig(level=logging.INFO,\n",
    "                    format=\"%(asctime)s | %(levelname)s | %(message)s\")\n",
    "logger=logging.getLogger(\"BronzeETL\")\n",
    "\n",
    "url=URL.create(\n",
    "    drivername=\"mysql+pymysql\",\n",
    "    username=\"root\",\n",
    "    password=\"your password\",\n",
    "    host=\"localhost\",\n",
    "    port=3306,\n",
    "    database=\"bronze\"\n",
    ")\n",
    "engine=create_engine(url)\n",
    "\n",
    "results=[]\n",
    "\n",
    "for ds in DATASETS:\n",
    "    start=datetime.now()\n",
    "    src=ds[\"file_path\"]\n",
    "    table=ds[\"table\"]\n",
    "    status=\"SUCCESS\"\n",
    "    error=\"\"\n",
    "    try:\n",
    "        logger.info(f\"Processing {table}\")\n",
    "        df=pd.read_csv(src)\n",
    "        df.columns=df.columns.str.strip()\n",
    "        df=df.drop_duplicates()\n",
    "\n",
    "        with engine.begin() as conn:\n",
    "            exists=conn.execute(text(\"\"\"\n",
    "            SELECT COUNT(*)\n",
    "            FROM information_schema.tables\n",
    "            WHERE table_schema=:db AND table_name=:tbl\n",
    "            \"\"\"),{\"db\":DB_NAME,\"tbl\":table}).scalar()\n",
    "\n",
    "            if not exists:\n",
    "                raise Exception(f\"Target table {DB_NAME}.{table} does not exist.\")\n",
    "\n",
    "            conn.execute(text(f\"TRUNCATE TABLE `{table}`\"))\n",
    "\n",
    "        df.to_sql(\n",
    "            table,\n",
    "            con=engine,\n",
    "            if_exists=\"append\",\n",
    "            index=False,\n",
    "            chunksize=5000,\n",
    "            method=\"multi\"\n",
    "        )\n",
    "\n",
    "        tgt=pd.read_sql(f\"SELECT COUNT(*) cnt FROM `{table}`\",engine).iloc[0,0]\n",
    "\n",
    "        results.append({\n",
    "            \"Table\":table,\n",
    "            \"Source Rows\":len(df),\n",
    "            \"Target Rows\":tgt,\n",
    "            \"Status\":\"SUCCESS\",\n",
    "            \"Duration\":str(datetime.now()-start),\n",
    "            \"Error\":\"\"\n",
    "        })\n",
    "\n",
    "    except Exception as ex:\n",
    "        status=\"FAILED\"\n",
    "        error=str(ex)\n",
    "        logger.exception(error)\n",
    "        results.append({\n",
    "            \"Table\":table,\n",
    "            \"Source Rows\":\"\",\n",
    "            \"Target Rows\":\"\",\n",
    "            \"Status\":status,\n",
    "            \"Duration\":str(datetime.now()-start),\n",
    "            \"Error\":error\n",
    "        })\n",
    "\n",
    "summary=pd.DataFrame(results)\n",
    "print(summary)\n"
   ]
